<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ads_black">

    <!-- Stretched ambient blur background -->
    <ImageView
        android:id="@+id/ivAdImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.6"
        android:importantForAccessibility="no"
        tools:src="@tools:sample/backgrounds/scenic" />

    <!-- Dark gradient overlay for bottom text contrast -->
    <View
        android:layout_width="match_parent"
        android:layout_height="350dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@drawable/interstitial_gradient_overlay" />

    <!-- Prominent Close Button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardClose"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="@color/ads_close_bg"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/close_ad"
            android:src="@drawable/ic_close"
            android:padding="8dp"/>
    </androidx.cardview.widget.CardView>

    <!-- Ad Badge -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@drawable/ad_badge_bg"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:text="@string/ad_badge"
        android:textColor="@color/ads_white"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Feature graphic placed prominently (centered in available upper space) -->
    <ImageView
        android:id="@+id/ivFeatureGraphic"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="H,2:1"
        android:layout_marginHorizontal="24dp"
        android:background="@drawable/bg_rounded_feature"
        android:clipToOutline="true"
        android:elevation="16dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toBottomOf="@+id/cardClose"
        app:layout_constraintBottom_toTopOf="@+id/coreContainer"
        app:layout_constraintVertical_bias="0.45" />

    <!-- Core App Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/coreContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/iconContainer"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/ads_icon_bg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivAdIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:src="@tools:sample/avatars" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvAdTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/ads_white"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/iconContainer"
            app:layout_constraintTop_toTopOf="@+id/iconContainer"
            app:layout_constraintBottom_toTopOf="@+id/tvAdDescription"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="App Title" />

        <TextView
            android:id="@+id/tvAdDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/ads_text_light"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@+id/iconContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/iconContainer"
            app:layout_constraintTop_toBottomOf="@+id/tvAdTitle"
            tools:text="App description goes here and might span two lines" />

        <!-- Rating + Installs row -->
        <LinearLayout
            android:id="@+id/metaRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            app:layout_constraintStart_toEndOf="@+id/iconContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvAdDescription">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_star"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/tvRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:textColor="@color/ads_badge_bg"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="4.5" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:text="·"
                android:textColor="@color/ads_text_light"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvInstalls"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ads_text_light"
                android:textSize="13sp"
                tools:text="100,000+ installs" />

        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnInstall"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="@string/install"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/ads_white"
            android:background="@drawable/ads_btn_bg"
            app:layout_constraintTop_toBottomOf="@+id/metaRow" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
