<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/ads_white"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <!-- Ad badge -->
    <TextView
        android:id="@+id/tvAdBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/ad_badge_bg"
        android:paddingHorizontal="4dp"
        android:paddingVertical="1dp"
        android:text="@string/ad_badge"
        android:textColor="@color/ads_white"
        android:textSize="9sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- App icon -->
    <androidx.cardview.widget.CardView
        android:id="@+id/iconContainer"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginTop="6dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/ads_icon_bg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvAdBadge">

        <ImageView
            android:id="@+id/ivAdIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            tools:src="@tools:sample/avatars" />
    </androidx.cardview.widget.CardView>

    <!-- Title -->
    <TextView
        android:id="@+id/tvAdTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/ads_text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/btnInstall"
        app:layout_constraintStart_toEndOf="@+id/iconContainer"
        app:layout_constraintTop_toTopOf="@+id/iconContainer"
        app:layout_constraintBottom_toTopOf="@+id/tvAdDescription"
        app:layout_constraintVertical_chainStyle="packed"
        tools:text="App Title" />

    <!-- Description -->
    <TextView
        android:id="@+id/tvAdDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/ads_text_secondary"
        android:textSize="13sp"
        app:layout_constraintEnd_toStartOf="@+id/btnInstall"
        app:layout_constraintStart_toEndOf="@+id/iconContainer"
        app:layout_constraintTop_toBottomOf="@+id/tvAdTitle"
        app:layout_constraintBottom_toBottomOf="@+id/iconContainer"
        tools:text="Short description of the app" />

    <!-- Small Install button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnInstall"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="@string/install"
        android:textSize="12sp"
        android:textColor="@color/ads_white"
        android:background="@drawable/ads_btn_bg"
        android:paddingHorizontal="16dp"
        android:textAllCaps="false"
        app:layout_constraintBottom_toBottomOf="@+id/iconContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/iconContainer" />

    <!-- Bottom separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="@color/ads_border"
        app:layout_constraintTop_toBottomOf="@+id/iconContainer" />

</androidx.constraintlayout.widget.ConstraintLayout>
