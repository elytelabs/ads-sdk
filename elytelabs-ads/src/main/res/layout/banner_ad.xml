<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="0dp"
    app:cardElevation="2dp"
    android:layout_margin="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/elyte_ads_white"
        android:padding="8dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/iconContainer"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivAdIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/elyte_ads_icon_bg"
                tools:src="@tools:sample/avatars" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvAdTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textStyle="bold"
            android:textColor="@color/elyte_ads_text_primary"
            android:textSize="14sp"
            app:layout_constraintEnd_toStartOf="@+id/btnInstall"
            app:layout_constraintStart_toEndOf="@+id/iconContainer"
            app:layout_constraintTop_toTopOf="@+id/iconContainer"
            tools:text="Ad Title" />

        <TextView
            android:id="@+id/tvAdDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/elyte_ads_text_secondary"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@+id/iconContainer"
            app:layout_constraintEnd_toStartOf="@+id/btnInstall"
            app:layout_constraintStart_toEndOf="@+id/iconContainer"
            app:layout_constraintTop_toBottomOf="@+id/tvAdTitle"
            tools:text="Ad Description goes here and might span two lines" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnInstall"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/install"
            android:textSize="12sp"
            android:textColor="@color/elyte_ads_white"
            android:background="@drawable/elyte_ads_btn_bg"
            android:paddingHorizontal="16dp"
            android:textAllCaps="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/ad_badge_bg"
            android:paddingHorizontal="4dp"
            android:paddingVertical="1dp"
            android:text="@string/ad_badge"
            android:textColor="@color/elyte_ads_white"
            android:textSize="9sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
