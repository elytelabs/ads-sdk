<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/ads_white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Ad badge -->
        <TextView
            android:id="@+id/tvAdBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:background="@drawable/ad_badge_bg"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="@string/ad_badge"
            android:textColor="@color/ads_white"
            android:textSize="10sp"
            android:textStyle="bold"
            android:elevation="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Featured image (blurred icon as hero) -->
        <ImageView
            android:id="@+id/ivAdImage"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:background="@color/ads_icon_bg"
            android:importantForAccessibility="no"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@tools:sample/backgrounds/scenic" />

        <!-- App icon overlapping the image -->
        <androidx.cardview.widget.CardView
            android:id="@+id/iconContainer"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/ads_icon_bg"
            app:layout_constraintBottom_toBottomOf="@+id/ivAdImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ivAdImage">

            <ImageView
                android:id="@+id/ivAdIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:src="@tools:sample/avatars" />
        </androidx.cardview.widget.CardView>

        <!-- Title -->
        <TextView
            android:id="@+id/tvAdTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="36dp"
            android:layout_marginEnd="16dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/ads_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/iconContainer"
            app:layout_constraintTop_toBottomOf="@+id/ivAdImage"
            tools:text="App Title Here" />

        <!-- Description -->
        <TextView
            android:id="@+id/tvAdDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingHorizontal="16dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/ads_text_secondary"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@+id/tvAdTitle" />

        <!-- Rating + Installs row -->
        <LinearLayout
            android:id="@+id/metaRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:paddingHorizontal="16dp"
            android:orientation="horizontal"
            android:gravity="centerVertical"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@+id/tvAdDescription">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_star"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/tvRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:textColor="@color/ads_text_secondary"
                android:textSize="12sp"
                tools:text="4.5" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:text="·"
                android:textColor="@color/ads_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvInstalls"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ads_text_secondary"
                android:textSize="12sp"
                tools:text="100,000+ installs" />

        </LinearLayout>

        <!-- Install button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnInstall"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:text="@string/install"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/ads_white"
            android:textAllCaps="false"
            android:background="@drawable/ads_btn_bg"
            app:layout_constraintTop_toBottomOf="@+id/metaRow"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
